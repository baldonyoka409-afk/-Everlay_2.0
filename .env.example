# OpenRouter API Configuration
OPENROUTER_API_KEY=your_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
OPENROUTER_HTTP_REFERER=https://github.com/your-repo/everlay
OPENROUTER_X_TITLE=Everlay AI Environment

# Model lists (comma-separated)
OPENROUTER_FREE_MODELS=nvidia/nemotron-3-ultra-550b-a55b:free,poolside/laguna-m.1:free,nvidia/nemotron-3-super-120b-a12b:free,cohere/north-mini-code:free,poolside/laguna-xs-2.1:free,openai/gpt-oss-120b:free,nvidia/nemotron-3-nano-30b-a3b:free,google/gemma-4-31b-it:free,nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free,nvidia/nemotron-nano-9b-v2:free,openai/gpt-oss-20b:free
OPENROUTER_PAID_MODELS=openai/gpt-4o-mini,openai/gpt-4o,anthropic/claude-3.5-sonnet,google/gemini-2.5-pro,meta-llama/llama-3.1-405b-instruct

# Ollama Configuration (local embeddings)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SECONDS=30

# Embedding provider: ollama | openrouter | hash | auto (default: auto tries ollama -> openrouter -> hash)
EMBEDDING_PROVIDER=auto

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=8207197424:AAHCU74CYwu8tU09RSN8yuCon0oGeHot0KE
TELEGRAM_ALLOWED_USERS=123456789  # Comma-separated list of allowed user IDs

# Agent Configuration
AGENT_DEFAULT_TEMPERATURE=0.7
AGENT_DEFAULT_MAX_TOKENS=4096
AGENT_TIMEOUT_SECONDS=120
AGENT_DEFAULT_SYSTEM_PROMPT="You are a helpful AI assistant."

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/agents.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Application Settings
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Database (SQLite for local development)
DATABASE_URL=sqlite:///./everlay.db
RAG_DB_PATH=everlay_brain.db

# Redis (optional, for caching/sessions)
REDIS_URL=redis://localhost:6379/0

# Web Interface
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_SECRET_KEY=your-secret-key-change-in-production
WEB_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Agent Defaults
DEFAULT_AGENT_MODEL=openai/gpt-4o-mini
DEFAULT_AGENT_TEMPERATURE=0.7
DEFAULT_AGENT_MAX_TOKENS=4096
MAX_CONVERSATION_HISTORY=50